{
  "name": "@capsium/core",
  "version": "0.2.0",
  "description": "Capsium domain models (zod schemas), legacy normalization, manifest/routes auto-generation and integrity logic. Isomorphic (no Node or browser specific APIs).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/capsiums/capsium-js.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsup && yarn build:schemas",
    "build:schemas": "node scripts/generate-schemas.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
