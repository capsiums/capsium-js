{
  "name": "@capsium/packager",
  "version": "0.1.0",
  "description": "Node-side .cap tooling: read/validate packages, generate manifest/routes, SHA-256 checksums, write and extract .cap archives, verify integrity.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capsium/core": "workspace:^",
    "fflate": "^0.8.3",
    "zod": "^4.4.3"
  }
}
