{
  "name": "capsium",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "test": "yarn workspaces foreach -A run test",
