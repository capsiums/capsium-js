    "typecheck": "yarn workspaces foreach -A run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
